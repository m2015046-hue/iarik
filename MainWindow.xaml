<Window x:Class="PolApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PolApp"
        mc:Ignorable="d"
        Title="Мастер пол" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="40"/>
        </Grid.RowDefinitions>
        <Frame Grid.Row="1" Name="MainFrame" NavigationUIVisibility="Hidden" ContentRendered="MainFrame_ContentRendered"/>
        <Grid Grid.Row="0" Background="{StaticResource Beige}">
            <Image Source="/Resources/MasterPol.png" HorizontalAlignment="Left"/>
            <TextBlock Text="Мастер пол" FontSize="40" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            <Button x:Name="BackButton" Content="Назад" HorizontalAlignment="Right" Click="BackButton_Click" Margin="0 0 10 0"/>
        </Grid>
        <Grid Grid.Row="2" Background="{StaticResource Beige}">
            <TextBlock Name="LoginText" FontSize="15" Margin="5 0 0 0"/>
            <Button x:Name="LogoutButton" Content="Выйти" HorizontalAlignment="Right" Click="LogoutButton_Click" Margin="0 0 10 0"/>
        </Grid>
    </Grid>
</Window>

