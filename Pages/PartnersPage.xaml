<Page x:Class="PolApp.Pages.PartnersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:PolApp.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="PartnersPage" IsVisibleChanged="Page_IsVisibleChanged">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <ListBox x:Name="ListBoxPartners" Background="#f5f5f5" Grid.Row="1" ScrollViewer.VerticalScrollBarVisibility="Visible" HorizontalContentAlignment="Stretch">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Background="White" Margin="5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Orientation="Vertical" HorizontalAlignment="Left" VerticalAlignment="Top"  Margin="10">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontSize="20" Text="{Binding Partners_type.nameTypePartner}" Margin="0 0 5 0"/>
                                <TextBlock FontSize="20" Text="{Binding namePartner}"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Height="20">
                                <TextBlock FontSize="14" Text="{Binding surnameDirector, StringFormat={}Директор: {0}}"/>
                                <TextBlock FontSize="14" Text="{Binding nameDirector}" Margin="5 0"/>
                                <TextBlock FontSize="14" Text="{Binding patronymicDirector}"/>
                            </StackPanel>
                            <TextBlock FontSize="14" Text="{Binding phone, StringFormat={}+{0}}"/>
                            <TextBlock FontSize="14" Text="{Binding rate, StringFormat={}Рейтинг: {0}}"/>
                            <Button x:Name="EditButton" Content="Редактировать" Width="150" HorizontalAlignment="Left" Click="EditButton_Click" Margin="0 5"/>
                        </StackPanel>
                        <Button x:Name="HistoryButton" Content="История" Width="100" HorizontalAlignment="Center" VerticalAlignment="Bottom" Grid.Column="1" Click="HistoryButton_Click" Margin="0 10"/>
                        <TextBlock FontSize="25" HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0 10" Text="{Binding GetDiscount}" Grid.Column="1"/>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        <Grid Grid.Row="0" Background="{StaticResource Beige}">
            <Button x:Name="AddButton" Content="Добавить" Width="100" HorizontalAlignment="Right" Margin="5 0" Click="AddButton_Click" />
            <Button x:Name="DeleteButton" Content="Удалить" Width="100" HorizontalAlignment="Right" Margin="110 0" Click="DeleteButton_Click" />
        </Grid>
    </Grid>
</Page>
