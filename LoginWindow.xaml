<Window x:Class="PolApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PolApp"
        mc:Ignorable="d"
        Title="Авторизация" Height="450" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="70"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>
        <Grid Background="{StaticResource Beige}">
            <Image Source="/Resources/MasterPol.png" HorizontalAlignment="Left"/>
            <TextBlock Text="Авторизация" VerticalAlignment="Center" HorizontalAlignment="Center" FontSize="40"/>
        </Grid>
        <TextBlock Text="Логин" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Row="1" Margin="30 0 0 0" FontSize="30"/>
        <TextBox x:Name="LoginBox" Grid.Row="1" Margin="150 0 100 0"/>
        <TextBlock Text="Пароль" VerticalAlignment="Center" HorizontalAlignment="Left" Grid.Row="2" Margin="30 0 0 0" FontSize="30"/>
        <PasswordBox x:Name="PassBox" Grid.Row="2"  Height="40" Margin="150 0 100 0"/>
        <Grid Background="{StaticResource Beige}" Grid.Row="3">
            <Button x:Name="OkButton" Content="Войти" HorizontalAlignment="Center" VerticalAlignment="Center" Width="150" Click="OkButton_Click"/>
        </Grid>
    </Grid>
</Window>
